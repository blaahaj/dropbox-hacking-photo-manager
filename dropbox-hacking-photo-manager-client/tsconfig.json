{
  "compilerOptions": {
    // "baseUrl": "src",
    "rootDir": ".",
    "jsx": "react",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "outDir": "./public/dist/",
    "paths": {
      "@components/*": ["./src/components/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@lib/*": ["./src/lib/*"],
      "@pages/*": ["./src/pages/*"]
    },
    "resolveJsonModule": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "target": "es6"
  },
  "references": [
    {
      "path": "../dropbox-hacking-photo-manager-shared"
    }
  ]
}
